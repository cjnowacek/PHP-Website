# Serve index.php automatically in directories
DirectoryIndex index.php

# Custom error page
ErrorDocument 404 /404.php

# Contact form submissions must never be web-readable
<Files "contact_submissions.json">
    Require all denied
</Files>

RewriteEngine On
RewriteBase /

# Old Whisper URL and singular/plural typo permutations
# (renamed Jul 2026 to match the game's actual title; canonical is
# whispers-from-the-star, which must NOT match here or it would loop)
RewriteRule ^pages-techart/(whisper-from-the-stars|whispers-from-the-stars|whisper-from-the-star)(/.*)?$ /pages-techart/whispers-from-the-star$2 [R=301,L]

# --- Option 1: clean /pages-techart/runaway/ URLs ---

# 1) Redirect .../index.php → .../ (only when the client actually requested
#    index.php; without the THE_REQUEST guard this also fires on Apache's
#    internal DirectoryIndex subrequest and breaks "/" with a 403)
RewriteCond %{THE_REQUEST} \s/+([^?\s]*/)?index\.php[\s?]
RewriteRule ^(.*/)?index\.php$ /$1 [R=301,L]

# 2) Don’t rewrite real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --- Original clean-URL rules for flat .php pages ---

# 3) Redirect /foo.php → /foo
RewriteCond %{THE_REQUEST} \s/+([^.]+)\.php[\s?]
RewriteRule ^ %1 [R=301,L]

# 4) Map /foo → /foo.php if it exists
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# 5) Optional: /index → /
RewriteRule ^index/?$ / [R=301,L]
