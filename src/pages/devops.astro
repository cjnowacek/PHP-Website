---
// src/pages/devops.astro — ported from devops.php
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getProjectCards } from '../lib/projects.js';

const devopsProjects = await getProjectCards(['deadline-deploy', 'omnitool']);
---
<Layout title="DevOps">
  <div class="container" style="max-width: 1300px;">
    <h2>DevOps & Infrastructure</h2>

    <hr />

    <div style="text-align: center; margin: 40px 0;">
      <a
        href="/static/files/CJ-Nowacek-IT-Resume.pdf"
        class="resume-download-btn"
        target="_blank"
        rel="noopener">Download DevOps Resume (PDF)</a
      >
    </div>

    <h2>Core Competencies</h2>
    <div class="grid competencies-grid">
      <div class="grid-item">
        <div class="project-info">
          <h3>Render Farm Automation</h3>
          <p class="project-description">
            Unattended deployment of 3ds Max and its plugin stack across ~130 Windows render nodes
            via AWS Thinkbox Deadline
          </p>
        </div>
      </div>

      <div class="grid-item">
        <div class="project-info">
          <h3>Pipeline Tooling</h3>
          <p class="project-description">
            Python/PyQt applications for scene preparation and render-farm job submission — one
            codebase running as CLI, GUI, and natively inside 3ds Max
          </p>
        </div>
      </div>

      <div class="grid-item">
        <div class="project-info">
          <h3>Software Packaging &amp; Deployment</h3>
          <p class="project-description">
            Single-file PyInstaller builds with self-updating distribution, tuned to pass studio
            endpoint security (EDR)
          </p>
        </div>
      </div>

      <div class="grid-item">
        <div class="project-info">
          <h3>Windows Systems Automation</h3>
          <p class="project-description">
            SYSTEM-level execution via scheduled tasks, UNC-share orchestration, and standard-library
            Python (schtasks, robocopy)
          </p>
        </div>
      </div>
    </div>

    <h2>ML3DS — Render Farm Studio Pipeline</h2>
    <div class="about-text" style="max-width: 800px; margin: 0 auto 30px auto; text-align: left;">
      <p>
        Automation and tooling for a ~130-machine 3ds Max render farm — from unattended, farm-wide
        software deployment to a self-updating pipeline application shipped across two studios.
      </p>
    </div>
    <div class="projects-container">
      {devopsProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>

  <script>
    document.querySelectorAll('.project-card').forEach((item) => {
      item.addEventListener('mouseenter', () => {
        const gif = item.querySelector('.hover-gif');
        if (gif && gif.src) {
          gif.src = gif.src;
        }
      });
    });
  </script>
</Layout>
